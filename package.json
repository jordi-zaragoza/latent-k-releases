{
  "name": "latent-k",
  "version": "1.0.0",
  "description": "Auto-sync context for AI coding assistants (Claude Code, Gemini CLI)",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "lk": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node scripts/build.js",
    "build:all": "node scripts/build.js --all",
    "build:linux": "node scripts/build.js --linux",
    "build:macos": "node scripts/build.js --macos",
    "build:win": "node scripts/build.js --win"
  },
  "keywords": [
    "lk",
    "context",
    "ai",
    "claude",
    "gemini",
    "claude-code",
    "gemini-cli"
  ],
  "author": "Jordi Zaragoza <j.z.cuffi@gmail.com>",
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "0.71.2",
    "@google/generative-ai": "0.24.1",
    "commander": "14.0.2",
    "conf": "15.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@vercel/ncc": "0.38.4",
    "@yao-pkg/pkg": "6.11.0",
    "esbuild": "0.27.2",
    "vitest": "4.0.17"
  }
}
